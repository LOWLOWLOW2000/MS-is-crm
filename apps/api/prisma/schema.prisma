// IS-CRM Prisma Schema
// 全テーブルに tenantId 必須（マルチテナント）
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  name         String
  passwordHash String?
  role         String    // UserRole
  createdAt    String
  updatedAt    String

  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  tokenHash String
  expiresAt String
  createdAt String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model CallingRecord {
  id            String   @id @default(cuid())
  tenantId      String
  createdBy    String
  companyName  String
  companyPhone String
  companyAddress String
  targetUrl    String
  approved     Boolean
  approvedAt   String?
  approvedBy   String?
  result       String   // CallingResultType
  memo         String   @default("")
  nextCallAt   String?
  createdAt    String
  updatedAt    String

  @@index([tenantId])
  @@index([tenantId, nextCallAt])
  @@map("calling_records")
}

model CallingApproval {
  id          String @id @default(cuid())
  tenantId    String
  approvedBy  String
  approvedAt String
  targetUrl   String
  companyName String

  @@index([tenantId])
  @@map("calling_approvals")
}

model CallingHelpRequest {
  id              String   @id @default(cuid())
  tenantId        String
  requestedBy     String
  requestedByEmail String
  companyName    String
  scriptTab       String
  requestedAt    String
  queueNumber     Int      @default(0)
  status         String   // waiting | joined | closed
  joinedBy        String?
  joinedAt       String?
  resolvedAt     String?

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("calling_help_requests")
}

model CallingSettings {
  tenantId            String @id
  humanApprovalEnabled Boolean
  updatedBy           String
  updatedAt           String

  @@map("calling_settings")
}

model CallingList {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  sourceType     String   @default("csv")
  createdBy      String
  createdAt      String
  itemCount      Int      @default(0)
  assigneeEmail  String?
  assignedBy     String?
  assignedAt     String?

  items ListItem[]

  @@index([tenantId])
  @@map("calling_lists")
}

model ListItem {
  id           String   @id @default(cuid())
  tenantId     String
  listId       String
  companyName  String
  phone        String
  address      String
  targetUrl    String
  industryTag  String?
  createdAt    String

  list CallingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([listId])
  @@map("list_items")
}

model ScriptTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  industryTag String?
  tabs        Json     // ScriptTab[]
  createdBy   String
  updatedBy   String
  createdAt   String
  updatedAt   String

  @@index([tenantId])
  @@map("script_templates")
}

model CallingAiEvaluation {
  id             String   @id @default(cuid())
  tenantId       String
  callRecordId   String
  evaluatedAt    String
  categoryScores Json     // AiCategoryScore[]
  summary        String?
  improvementPoints Json? // string[]

  @@index([tenantId])
  @@index([callRecordId])
  @@map("calling_ai_evaluations")
}

// Phase2: ZOOM録音バッチDL → Whisper文字起こし結果を保存（永続）。元音声は別ストレージで30日削除。
model CallTranscription {
  id               String   @id @default(cuid())
  tenantId         String
  callRecordId     String
  zoomMeetingId    String?
  recordingStorageUrl String?  // 参照用。実体はSupabase等で30日後に削除
  durationSeconds  Int?
  transcribedAt    String
  transcriptionText String   @default("")
  createdAt        String

  @@index([tenantId])
  @@index([callRecordId])
  @@map("call_transcriptions")
}

// -----------------------------
// List generation (Phase2+)
// -----------------------------

model ListAreaMaster {
  id        String @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean @default(true)
  createdAt String
  updatedAt String

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("list_area_masters")
}

model ListIndustryMaster {
  id        String @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean @default(true)
  createdAt String
  updatedAt String

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("list_industry_masters")
}

model ListKeywordMaster {
  id        String @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean @default(true)
  createdAt String
  updatedAt String

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("list_keyword_masters")
}

model ListGenerationRequest {
  id            String  @id @default(cuid())
  tenantId      String
  requestedBy   String
  requestedByEmail String
  assignedToEmail  String
  // 構造化入力（まずは案A: 選択式マスタID + 追加条件をJsonで保持）
  input         Json
  status        String  // queued | running | completed | failed
  resultListId  String?
  errorMessage  String?
  createdAt     String
  updatedAt     String

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedToEmail])
  @@map("list_generation_requests")
}

// 運営側で集約する（PIIマスク済み）生成条件ログ
// 注意: 本番SaaSでは別ストレージ/別DB等も検討余地あり。ここでは最小の箱だけ用意。
model OperatorListGenerationLog {
  id            String @id @default(cuid())
  tenantId      String
  requesterRole String
  inputMasked   Json
  createdAt     String

  @@index([tenantId])
  @@map("operator_list_generation_logs")
}

// -----------------------------
// Phase4 雛形: テナント・プラン（マルチテナント化）
// -----------------------------

model Tenant {
  id          String   @id @default(cuid())
  name        String
  planId      String?
  isActive    Boolean  @default(true)
  createdAt   String
  updatedAt   String

  @@index([planId])
  @@map("tenants")
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  maxUsers    Int?
  maxLists    Int?
  features    Json?    // 機能フラグ等
  createdAt   String
  updatedAt   String

  @@map("plans")
}

