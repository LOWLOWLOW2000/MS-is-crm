// IS-CRM Prisma Schema
// 全テーブルに tenantId 必須（マルチテナント）
generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  /** 表示名（テナント内で一意） */
  name         String
  /** 本名・姓（課金・請求用。プロフィール API では返却しない） */
  familyName   String?
  /** 本名・名（課金・請求用。プロフィール API では返却しない） */
  givenName    String?
  /** 部署名（任意） */
  departmentName String?
  passwordHash String?
  /** 後方互換・単一ロール参照用（JWT の主ロール計算にも利用） */
  role         String
  /** 複数ロール（空のときは role を1件として扱う） */
  roles        String[]  @default([])
  /** プロフィール画像 URL（任意） */
  profileImageUrl String?
  /** ISO 3166-1 alpha-2（未設定時は UI で JP 扱い可） */
  countryCode  String?
  /** 住所表示用・都道府県（日本想定） */
  prefecture   String?
  /** 携帯電話番号 */
  mobilePhone  String?
  /** Slack メンバー ID（表示名・連携用） */
  slackId      String?
  createdAt    String
  updatedAt    String

  refreshTokens        RefreshToken[]
  projectMemberships ProjectMembership[]

  @@unique([tenantId, email])
  @@index([tenantId])
  /** 表示名の重複は API 層で同一テナント内を拒否（DB 一意制約は既存データ互換のため未付与） */
  @@index([tenantId, name])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  tokenHash String
  expiresAt String
  createdAt String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model CallingRecord {
  callingHistoryId String   @id @default(cuid()) @map("calling_history_id")
  tenantId         String
  createdBy       String
  companyName     String
  companyPhone    String
  companyAddress  String
  targetUrl       String
  approved        Boolean
  approvedAt      String?
  approvedBy      String?
  result          String   // CallingResultType
  memo            String   @default("")
  nextCallAt      String?
  /** ディレクター未読管理: null = 未読 */
  directorReadAt  String?
  /** 既読化したディレクターの userId */
  directorReadBy  String?
  createdAt       String
  updatedAt       String

  @@index([tenantId])
  @@index([tenantId, nextCallAt])
  @@index([tenantId, result, directorReadAt])
  @@map("calling_records")
}

/** リスト精査終了（リスト確認が承認終わった時点）。ID = リスト精査終了ID、日付 = リスト精査終了日 */
model ListReviewCompletion {
  id                String   @id @default(cuid()) // リスト精査終了ID
  tenantId          String
  completedBy       String
  reviewCompletedAt String   // リスト精査終了日
  targetUrl         String
  companyName       String

  @@index([tenantId])
  @@map("list_review_completions")
}

model CallingHelpRequest {
  id              String   @id @default(cuid())
  tenantId        String
  requestedBy     String
  requestedByEmail String
  companyName    String
  scriptTab       String
  requestedAt    String
  queueNumber     Int      @default(0)
  status         String   // waiting | joined | closed
  joinedBy        String?
  joinedAt       String?
  resolvedAt     String?

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("calling_help_requests")
}

model CallingSettings {
  tenantId            String @id
  humanApprovalEnabled Boolean
  updatedBy           String
  updatedAt           String

  @@map("calling_settings")
}

model KpiGoal {
  id                    String @id @default(cuid())
  tenantId              String
  projectId             String
  goalKey               String
  scope                 String
  targetUserId          String?
  callPerHour           Float  @default(0)
  appointmentRate       Float  @default(0)
  materialSendRate      Float  @default(0)
  redialAcquisitionRate Float  @default(0)
  cutContactRate        Float  @default(0)
  keyPersonContactRate  Float  @default(0)
  updatedBy             String
  updatedAt             String

  @@unique([tenantId, goalKey])
  @@index([tenantId])
  @@index([projectId])
  @@index([tenantId, scope, targetUserId])
  @@map("kpi_goals")
}

model CallingList {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  sourceType     String   @default("csv")
  createdBy      String
  createdAt      String
  itemCount      Int      @default(0)
  assigneeEmail  String?
  assignedBy     String?
  assignedAt     String?

  items ListItem[]

  @@index([tenantId])
  @@map("calling_lists")
}

model ListItem {
  id             String   @id @default(cuid())
  tenantId       String
  listId         String
  legalEntityId  String?  // L2 法人エンティティへの参照（企業ツリー）
  companyName    String
  phone          String
  address        String
  targetUrl      String
  industryTag    String?
  /** 担当割当（User.id） */
  assignedToUserId String?
  assignedAt      String?
  assignedByUserId String?
  /** 進捗ステータス（unstarted|calling|done|excluded） */
  status          String   @default("unstarted")
  statusUpdatedAt String?
  completedAt     String?
  /** AIリスト判定ティア（A|B|C）。未設定可 */
  aiListTier      String?
  createdAt      String

  list        CallingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([listId])
  @@index([legalEntityId])
  @@index([tenantId, assignedToUserId])
  @@index([tenantId, status])
  @@map("list_items")
}

// -----------------------------
// 企業データベース・論理ツリー（L1〜L5）
// -----------------------------

/** L1: 企業グループ（Ultimate Parent） */
model CompanyGroup {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  listedFlag  String?  // 上場・非上場
  creditInfo  String?  // グループ全体与信・系列情報（テキストまたはJSON）
  createdAt   String
  updatedAt   String

  legalEntities LegalEntity[]

  @@index([tenantId])
  @@map("company_groups")
}

/** L2: 法人エンティティ（Legal Entity / 法人番号単位） */
model LegalEntity {
  id               String   @id @default(cuid())
  tenantId         String
  companyGroupId   String?
  corporateNumber  String?  // 法人番号
  name             String   // 商号
  headOfficeAddress String?
  /** 画面用ステータス（将来の精査/配布フローに利用） */
  status           String?
  establishedAt    String?
  capital          String?  // 資本金（文字で保持）
  revenue          String?  // 売上高
  operatingProfit  String?  // 営業利益
  fiscalYearEnd    String?  // 決算期
  createdAt        String
  updatedAt        String

  companyGroup   CompanyGroup?   @relation(fields: [companyGroupId], references: [id], onDelete: SetNull)
  establishments Establishment[]
  departments    Department[]
  personas       Persona[]
  listItems      ListItem[]
  snapshots      LegalEntitySnapshot[]

  @@index([tenantId])
  @@index([companyGroupId])
  @@map("legal_entities")
}

/** 会社情報の更新履歴（スナップショット）。更新前の状態を保存する。 */
model LegalEntitySnapshot {
  id            String   @id @default(cuid())
  tenantId      String
  legalEntityId String
  snapshot      Json
  createdBy     String
  createdAt     String

  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([legalEntityId])
  @@index([tenantId, legalEntityId, createdAt])
  @@map("legal_entity_snapshots")
}

/** L3: 拠点・事業所（Establishment） */
model Establishment {
  id            String   @id @default(cuid())
  tenantId      String
  legalEntityId String
  name          String
  address       String?
  type          String?  // 営業所・製造・R&D 等
  createdAt     String
  updatedAt     String

  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([legalEntityId])
  @@map("establishments")
}

/** L4: 組織・部署（Department） */
model Department {
  id            String   @id @default(cuid())
  tenantId      String
  legalEntityId String
  name          String   // 部署名
  roleCategory  String?  // 営業・人事・情報システム 等
  createdAt     String
  updatedAt     String

  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  personas    Persona[]

  @@index([tenantId])
  @@index([legalEntityId])
  @@map("departments")
}

/** L5: 担当者・キーマン（Persona） */
model Persona {
  id            String   @id @default(cuid())
  tenantId      String
  legalEntityId String
  departmentId  String?
  name          String   // 担当者名
  phone         String?  // 電話番号
  email         String?  // メールアドレス
  roleRank      String?  // 役職ランク
  authority     String?  // 決裁権限
  createdAt     String
  updatedAt     String

  legalEntity LegalEntity  @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  department  Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([legalEntityId])
  @@index([departmentId])
  @@map("personas")
}

model ScriptTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  industryTag String?
  tabs        Json     // ScriptTab[]
  createdBy   String
  updatedBy   String
  createdAt   String
  updatedAt   String

  @@index([tenantId])
  @@map("script_templates")
}

model CallingAiEvaluation {
  id             String   @id @default(cuid())
  tenantId       String
  callRecordId   String
  evaluatedAt    String
  categoryScores Json     // AiCategoryScore[]
  summary        String?
  improvementPoints Json? // string[]

  @@index([tenantId])
  @@index([callRecordId])
  @@map("calling_ai_evaluations")
}

// Phase2: ZOOM録音バッチDL → Whisper文字起こし結果を保存（永続）。元音声は別ストレージで30日削除。
model CallTranscription {
  id               String   @id @default(cuid())
  tenantId         String
  callRecordId     String
  zoomMeetingId    String?
  recordingStorageUrl String?  // 参照用。実体はSupabase等で30日後に削除
  durationSeconds  Int?
  transcribedAt    String
  transcriptionText String   @default("")
  createdAt        String

  @@index([tenantId])
  @@index([callRecordId])
  @@map("call_transcriptions")
}

// -----------------------------
// List generation (Phase2+)
// -----------------------------

model ListAreaMaster {
  id        String @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean @default(true)
  createdAt String
  updatedAt String

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("list_area_masters")
}

model ListIndustryMaster {
  id         String @id @default(cuid())
  tenantId   String
  name       String
  /** UIグループ（大分類ラベル）。中カテゴリは name で表現 */
  groupLabel String?
  isActive   Boolean @default(true)
  createdAt  String
  updatedAt  String

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("list_industry_masters")
}

model ListKeywordMaster {
  id        String @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean @default(true)
  createdAt String
  updatedAt String

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("list_keyword_masters")
}

model ListGenerationRequest {
  id            String  @id @default(cuid())
  tenantId      String
  requestedBy   String
  requestedByEmail String
  assignedToEmail  String
  // 構造化入力（まずは案A: 選択式マスタID + 追加条件をJsonで保持）
  input         Json
  status        String  // queued | running | completed | failed
  resultListId  String?
  errorMessage  String?
  createdAt     String
  updatedAt     String

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedToEmail])
  @@map("list_generation_requests")
}

// 運営側で集約する（PIIマスク済み）生成条件ログ
// 注意: 本番SaaSでは別ストレージ/別DB等も検討余地あり。ここでは最小の箱だけ用意。
model OperatorListGenerationLog {
  id            String @id @default(cuid())
  tenantId      String
  requesterRole String
  inputMasked   Json
  createdAt     String

  @@index([tenantId])
  @@map("operator_list_generation_logs")
}

// -----------------------------
// Phase4 雛形: テナント・プラン（マルチテナント化）
// -----------------------------

model Tenant {
  id                 String   @id @default(cuid())
  name               String
  planId             String?
  isActive           Boolean  @default(true)
  /** 企業プロフィール（ステータス登録） */
  companyName        String?
  headOfficeAddress  String?
  headOfficePhone    String?
  representativeName String?
  accountStatus      String   @default("active")
  /** ヘッダー等に出すPJ名（任意・未設定時は UI で「未設定」） */
  projectDisplayName String?
  createdAt          String
  updatedAt          String

  invitations TenantInvitation[]
  project     Project?

  @@index([planId])
  @@map("tenants")
}

/** テナントあたり1件の既定PJ（ヘッダー projectDisplayName と連動した表示名） */
model Project {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  name      String
  createdAt String
  updatedAt String

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships ProjectMembership[]

  @@index([tenantId])
  @@map("projects")
}

/** PJ単位の配役（User の director / is_member と同一トランザクションで更新） */
model ProjectMembership {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String
  userId    String
  pjRole    String
  createdAt String
  updatedAt String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("project_memberships")
}

/** 企業への招待（メール URL・3日・1回限り） */
model TenantInvitation {
  id               String   @id @default(cuid())
  tenantId         String
  email            String
  tokenHash        String   @unique
  invitedRoles     Json
  invitedByUserId  String
  expiresAt        String
  consumedAt       String?
  createdAt        String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, email])
  @@map("tenant_invitations")
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  maxUsers    Int?
  maxLists    Int?
  features    Json?    // 機能フラグ等
  createdAt   String
  updatedAt   String

  @@map("plans")
}

