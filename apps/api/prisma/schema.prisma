// IS-CRM Prisma Schema
// 全テーブルに tenantId 必須（マルチテナント）
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  name         String
  passwordHash String?
  role         String    // UserRole
  createdAt    String
  updatedAt    String

  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  tokenHash String
  expiresAt String
  createdAt String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model CallingRecord {
  callingHistoryId String   @id @default(cuid()) @map("calling_history_id")
  tenantId         String
  createdBy       String
  companyName     String
  companyPhone    String
  companyAddress  String
  targetUrl       String
  approved        Boolean
  approvedAt      String?
  approvedBy      String?
  result          String   // CallingResultType
  memo            String   @default("")
  nextCallAt      String?
  createdAt       String
  updatedAt       String

  @@index([tenantId])
  @@index([tenantId, nextCallAt])
  @@map("calling_records")
}

/** リスト精査終了（リスト確認が承認終わった時点）。ID = リスト精査終了ID、日付 = リスト精査終了日 */
model ListReviewCompletion {
  id                String   @id @default(cuid()) // リスト精査終了ID
  tenantId          String
  completedBy       String
  reviewCompletedAt String   // リスト精査終了日
  targetUrl         String
  companyName       String

  @@index([tenantId])
  @@map("list_review_completions")
}

model CallingHelpRequest {
  id              String   @id @default(cuid())
  tenantId        String
  requestedBy     String
  requestedByEmail String
  companyName    String
  scriptTab       String
  requestedAt    String
  queueNumber     Int      @default(0)
  status         String   // waiting | joined | closed
  joinedBy        String?
  joinedAt       String?
  resolvedAt     String?

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("calling_help_requests")
}

model CallingSettings {
  tenantId            String @id
  humanApprovalEnabled Boolean
  updatedBy           String
  updatedAt           String

  @@map("calling_settings")
}

model CallingList {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  sourceType     String   @default("csv")
  createdBy      String
  createdAt      String
  itemCount      Int      @default(0)
  assigneeEmail  String?
  assignedBy     String?
  assignedAt     String?

  items ListItem[]

  @@index([tenantId])
  @@map("calling_lists")
}

model ListItem {
  id             String   @id @default(cuid())
  tenantId       String
  listId         String
  legalEntityId  String?  // L2 法人エンティティへの参照（企業ツリー）
  companyName    String
  phone          String
  address        String
  targetUrl      String
  industryTag    String?
  createdAt      String

  list        CallingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([listId])
  @@index([legalEntityId])
  @@map("list_items")
}

// -----------------------------
// 企業データベース・論理ツリー（L1〜L5）
// -----------------------------

/** L1: 企業グループ（Ultimate Parent） */
model CompanyGroup {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  listedFlag  String?  // 上場・非上場
  creditInfo  String?  // グループ全体与信・系列情報（テキストまたはJSON）
  createdAt   String
  updatedAt   String

  legalEntities LegalEntity[]

  @@index([tenantId])
  @@map("company_groups")
}

/** L2: 法人エンティティ（Legal Entity / 法人番号単位） */
model LegalEntity {
  id               String   @id @default(cuid())
  tenantId         String
  companyGroupId   String?
  corporateNumber  String?  // 法人番号
  name             String   // 商号
  headOfficeAddress String?
  establishedAt    String?
  capital          String?  // 資本金（文字で保持）
  revenue          String?  // 売上高
  operatingProfit  String?  // 営業利益
  fiscalYearEnd    String?  // 決算期
  createdAt        String
  updatedAt        String

  companyGroup   CompanyGroup?   @relation(fields: [companyGroupId], references: [id], onDelete: SetNull)
  establishments Establishment[]
  departments    Department[]
  personas       Persona[]
  listItems      ListItem[]

  @@index([tenantId])
  @@index([companyGroupId])
  @@map("legal_entities")
}

/** L3: 拠点・事業所（Establishment） */
model Establishment {
  id            String   @id @default(cuid())
  tenantId      String
  legalEntityId String
  name          String
  address       String?
  type          String?  // 営業所・製造・R&D 等
  createdAt     String
  updatedAt     String

  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([legalEntityId])
  @@map("establishments")
}

/** L4: 組織・部署（Department） */
model Department {
  id            String   @id @default(cuid())
  tenantId      String
  legalEntityId String
  name          String   // 部署名
  roleCategory  String?  // 営業・人事・情報システム 等
  createdAt     String
  updatedAt     String

  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  personas    Persona[]

  @@index([tenantId])
  @@index([legalEntityId])
  @@map("departments")
}

/** L5: 担当者・キーマン（Persona） */
model Persona {
  id            String   @id @default(cuid())
  tenantId      String
  legalEntityId String
  departmentId  String?
  name          String   // 担当者名
  phone         String?  // 電話番号
  email         String?  // メールアドレス
  roleRank      String?  // 役職ランク
  authority     String?  // 決裁権限
  createdAt     String
  updatedAt     String

  legalEntity LegalEntity  @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  department  Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([legalEntityId])
  @@index([departmentId])
  @@map("personas")
}

model ScriptTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  industryTag String?
  tabs        Json     // ScriptTab[]
  createdBy   String
  updatedBy   String
  createdAt   String
  updatedAt   String

  @@index([tenantId])
  @@map("script_templates")
}

model CallingAiEvaluation {
  id             String   @id @default(cuid())
  tenantId       String
  callRecordId   String
  evaluatedAt    String
  categoryScores Json     // AiCategoryScore[]
  summary        String?
  improvementPoints Json? // string[]

  @@index([tenantId])
  @@index([callRecordId])
  @@map("calling_ai_evaluations")
}

// Phase2: ZOOM録音バッチDL → Whisper文字起こし結果を保存（永続）。元音声は別ストレージで30日削除。
model CallTranscription {
  id               String   @id @default(cuid())
  tenantId         String
  callRecordId     String
  zoomMeetingId    String?
  recordingStorageUrl String?  // 参照用。実体はSupabase等で30日後に削除
  durationSeconds  Int?
  transcribedAt    String
  transcriptionText String   @default("")
  createdAt        String

  @@index([tenantId])
  @@index([callRecordId])
  @@map("call_transcriptions")
}

// -----------------------------
// List generation (Phase2+)
// -----------------------------

model ListAreaMaster {
  id        String @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean @default(true)
  createdAt String
  updatedAt String

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("list_area_masters")
}

model ListIndustryMaster {
  id        String @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean @default(true)
  createdAt String
  updatedAt String

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("list_industry_masters")
}

model ListKeywordMaster {
  id        String @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean @default(true)
  createdAt String
  updatedAt String

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("list_keyword_masters")
}

model ListGenerationRequest {
  id            String  @id @default(cuid())
  tenantId      String
  requestedBy   String
  requestedByEmail String
  assignedToEmail  String
  // 構造化入力（まずは案A: 選択式マスタID + 追加条件をJsonで保持）
  input         Json
  status        String  // queued | running | completed | failed
  resultListId  String?
  errorMessage  String?
  createdAt     String
  updatedAt     String

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedToEmail])
  @@map("list_generation_requests")
}

// 運営側で集約する（PIIマスク済み）生成条件ログ
// 注意: 本番SaaSでは別ストレージ/別DB等も検討余地あり。ここでは最小の箱だけ用意。
model OperatorListGenerationLog {
  id            String @id @default(cuid())
  tenantId      String
  requesterRole String
  inputMasked   Json
  createdAt     String

  @@index([tenantId])
  @@map("operator_list_generation_logs")
}

// -----------------------------
// Phase4 雛形: テナント・プラン（マルチテナント化）
// -----------------------------

model Tenant {
  id          String   @id @default(cuid())
  name        String
  planId      String?
  isActive    Boolean  @default(true)
  createdAt   String
  updatedAt   String

  @@index([planId])
  @@map("tenants")
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  maxUsers    Int?
  maxLists    Int?
  features    Json?    // 機能フラグ等
  createdAt   String
  updatedAt   String

  @@map("plans")
}

