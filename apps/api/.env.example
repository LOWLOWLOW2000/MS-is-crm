PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/is_crm
DIRECT_URL=postgresql://user:password@localhost:5432/is_crm
WEB_BASE_URL=http://localhost:3000
# 開発: ngrok で Web を公開し、仲間のブラウザから API を叩くとき（手順4）必須。Web 側の https オリジン（カンマ区切り）
# CORS_EXTRA_ORIGINS=https://xxxx.ngrok-free.app
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=1d
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
ZOOM_WEBHOOK_VERIFICATION_TOKEN=replace-with-zoom-verification-token
ZOOM_WEBHOOK_SECRET_TOKEN=replace-with-zoom-secret-token
ZOOM_DEFAULT_TENANT_ID=tenant-demo-01
ZOOM_ACCOUNT_ID=replace-with-zoom-account-id
ZOOM_CLIENT_ID=replace-with-zoom-client-id
ZOOM_CLIENT_SECRET=replace-with-zoom-client-secret
ZOOM_API_BASE_URL=https://api.zoom.us/v2
