NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-string
API_BASE_URL=http://localhost:3001
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# PMV: Microsoft OAuth ボタンを出す場合のみ true（未設定・false なら Google のみ表示）
# NEXT_PUBLIC_ENABLE_MICROSOFT_OAUTH=true

# 架電看板: 開発時はモック有効。本番・Phase2でAPIのみにするときは false を設定
# NEXT_PUBLIC_CALLING_USE_MOCK_KANBAN=false

# アカウント作成：ストレージ案内のアフィリエイトリンク（任意。未設定時は公式URLへ）
# NEXT_PUBLIC_AFFILIATE_GOOGLE_DRIVE=https://...
# NEXT_PUBLIC_AFFILIATE_ONEDRIVE=https://...
# NEXT_PUBLIC_AFFILIATE_ICLOUD=https://...
# NEXT_PUBLIC_AFFILIATE_BOX=https://...
